---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Navigation from '../components/Navigation.astro';

interface Props {
  title: string;
  description?: string;
  section?: 'guide' | 'ethos' | 'questions';
}

const { title, description, section } = Astro.props;
---

<BaseLayout title={`${title} — walk · talk · meditate`} description={description}>
  <Header />
  <main class="max-w-wide mx-auto px-6 pb-12">
    <div class:list={['flex gap-20', section ? '' : 'justify-center']}>
      {section && <Navigation section={section} />}
      <article class="prose-content min-w-0 flex-1">
        <h1 class="mb-12 text-sand-800">{title}</h1>
        <slot />
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>
