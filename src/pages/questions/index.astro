---
import ContentLayout from '../../layouts/ContentLayout.astro';

const base = import.meta.env.BASE_URL;
---

<ContentLayout title="Questions" section="questions" description="Curated questions for walking, talking, and reflecting on pilgrimage.">
  <p>
    65 questions curated from the original 950 at
    <a href="https://savewisdom.org">savewisdom.org</a>, organized by
    how and when you'll use them.
  </p>

  <h2>How to Use</h2>

  <p>
    Each question is tagged with a stage — opening, middle, or
    closing — to help you choose based on where you are in your journey.
    Opening questions are lighter. Middle questions go deeper. Closing
    questions invite synthesis.
  </p>

  <p>
    One good question per walk or per evening discussion is enough. Let
    it breathe.
  </p>

  <h2>By Context</h2>

  <div class="mt-8 space-y-1 not-prose">
    <a href={`${base}questions/walking/`} class="group flex justify-between items-baseline py-4 border-b border-sand-100 dark:border-dusk-900">
      <span class="font-heading text-xl text-sand-800 dark:text-dusk-100 group-hover:text-sage dark:group-hover:text-sage-light transition-colors tracking-display">Walking</span>
      <span class="font-ui text-xs text-sand-300 dark:text-dusk-300">25 questions</span>
    </a>
    <a href={`${base}questions/evening/`} class="group flex justify-between items-baseline py-4 border-b border-sand-100 dark:border-dusk-900">
      <span class="font-heading text-xl text-sand-800 dark:text-dusk-100 group-hover:text-sage dark:group-hover:text-sage-light transition-colors tracking-display">Evening Discussion</span>
      <span class="font-ui text-xs text-sand-300 dark:text-dusk-300">15 questions</span>
    </a>
    <a href={`${base}questions/solo/`} class="group flex justify-between items-baseline py-4 border-b border-sand-100 dark:border-dusk-900">
      <span class="font-heading text-xl text-sand-800 dark:text-dusk-100 group-hover:text-sage dark:group-hover:text-sage-light transition-colors tracking-display">Solo Reflection</span>
      <span class="font-ui text-xs text-sand-300 dark:text-dusk-300">15 questions</span>
    </a>
    <a href={`${base}questions/morning/`} class="group flex justify-between items-baseline py-4 border-b border-sand-100 dark:border-dusk-900">
      <span class="font-heading text-xl text-sand-800 dark:text-dusk-100 group-hover:text-sage dark:group-hover:text-sage-light transition-colors tracking-display">Morning Seeds</span>
      <span class="font-ui text-xs text-sand-300 dark:text-dusk-300">10 questions</span>
    </a>
  </div>

  <h2>Credit</h2>

  <p>
    All questions sourced from <a href="https://savewisdom.org">savewisdom.org</a>.
    We selected those most relevant to pilgrimage — open-ended, cross-cultural,
    designed to invite depth.
  </p>
</ContentLayout>
