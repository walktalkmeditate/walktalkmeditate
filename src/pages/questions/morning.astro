---
import ContentLayout from '../../layouts/ContentLayout.astro';
import QuestionCard from '../../components/QuestionCard.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('questions', 'morning');
const { description, questions } = entry!.data;
---

<ContentLayout title="Morning Seeds" section="questions" description="One-sentence contemplative prompts for morning meditation.">
  <p>{description}</p>

  <div class="grid gap-4 mt-8 not-prose">
    {questions.map((q, i) => (
      <QuestionCard text={q.text} stage={q.stage} index={i + 1} />
    ))}
  </div>
</ContentLayout>
