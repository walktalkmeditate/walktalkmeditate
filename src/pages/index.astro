---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PillarCard from '../components/PillarCard.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="walk ⬡ talk ⬡ meditate">
  <Header />

  <main>
    <section class="max-w-4xl mx-auto px-6 pt-20 pb-16 md:pt-32 md:pb-24 text-center">
      <h1 class="font-heading text-5xl md:text-7xl font-semibold text-text mb-6 tracking-tight">
        walk ⬡ talk ⬡ meditate
      </h1>
      <p class="text-xl md:text-2xl text-text/60 font-body max-w-2xl mx-auto leading-relaxed">
        An open-source pilgrimage framework for harmonizing body, mind, and spirit.
      </p>
    </section>

    <section class="max-w-4xl mx-auto px-6 pb-16">
      <div class="prose-content text-center">
        <p class="text-lg text-text/70">
          Inspired by the walk-and-talk tradition — small group walks with deep conversations.
          Adding meditation as an equal third pillar transforms it into something more:
          a pilgrimage anyone can take, solo or with a group, local or abroad.
        </p>
        <p class="text-lg text-text/70">
          This is not another travel destination optimized for sightseeing and sensory overload.
          <strong class="text-text">Slow and chill is the motto. Relax and release is the practice.
          Peace and harmony is the way.</strong>
        </p>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 pb-20">
      <div class="grid md:grid-cols-3 gap-6">
        <PillarCard
          title="Walk"
          symbol="🚶"
          description="Walking as practice, not transit. Side by side, step by step — strengthening the physical body."
          href={`${base}walk/`}
        />
        <PillarCard
          title="Talk"
          symbol="💬"
          description="Deep reflection and connection, not small talk. Ask and share your unique perspective of reality."
          href={`${base}talk/`}
        />
        <PillarCard
          title="Meditate"
          symbol="🧘"
          description="Seek the peace and calmness within. Harmonize your being with the group and the environment."
          href={`${base}meditate/`}
        />
      </div>
    </section>

    <section class="max-w-3xl mx-auto px-6 pb-24 text-center">
      <a
        href={`${base}guide/getting-started/`}
        class="inline-block px-8 py-4 bg-accent text-white font-ui font-medium
               rounded-full hover:bg-accent/90 transition-colors text-lg"
      >
        Start your pilgrimage
      </a>
      <p class="mt-6 text-text/50 font-ui text-sm">
        No gear required. Start tomorrow in your own town.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>
