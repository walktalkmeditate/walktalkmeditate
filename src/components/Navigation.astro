---
interface Props {
  section: 'guide' | 'ethos' | 'questions';
}

const { section } = Astro.props;
const base = import.meta.env.BASE_URL;

const sections = {
  guide: {
    title: 'Guide',
    items: [
      { label: 'Getting Started', href: `${base}guide/getting-started/` },
      { label: 'Planning', href: `${base}guide/planning/` },
      { label: 'Preparing', href: `${base}guide/preparing/` },
      { label: 'On the Journey', href: `${base}guide/on-the-journey/` },
      { label: 'Coming Home', href: `${base}guide/coming-home/` },
    ],
  },
  ethos: {
    title: 'Ethos',
    items: [
      { label: 'Open Source', href: `${base}ethos/open-source/` },
      { label: 'The Golden Rule', href: `${base}ethos/golden-rule/` },
      { label: 'Radical Presence', href: `${base}ethos/radical-presence/` },
    ],
  },
  questions: {
    title: 'Questions',
    items: [
      { label: 'Overview', href: `${base}questions/` },
      { label: 'Walking', href: `${base}questions/walking/` },
      { label: 'Evening', href: `${base}questions/evening/` },
      { label: 'Solo', href: `${base}questions/solo/` },
      { label: 'Morning', href: `${base}questions/morning/` },
    ],
  },
};

const current = sections[section];
const currentPath = Astro.url.pathname;
---

<aside class="hidden lg:block w-40 shrink-0 pt-3">
  <nav class="sticky top-12">
    <p class="font-ui text-[11px] uppercase tracking-[0.15em] text-sand-300 dark:text-dusk-700 mb-5">
      {current.title}
    </p>
    <ul class="space-y-2">
      {current.items.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block font-ui text-[13px] transition-colors',
              currentPath.endsWith(item.href.replace(/\/$/, '') + '/') || currentPath.endsWith(item.href.replace(/\/$/, ''))
                ? 'text-sand-800 dark:text-dusk-100'
                : 'text-sand-400 dark:text-dusk-300 hover:text-sand-600 dark:hover:text-dusk-200',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>
